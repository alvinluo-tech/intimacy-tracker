    },
    {
      "src": "/screenshots/timeline.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Timeline — browse encounters"
    },
    {
      "src": "/screenshots/map.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Map — heatmap view"
    }
  ],
